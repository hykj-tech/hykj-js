{
  "compilerOptions": {
    "outDir": "dist",
    "declaration":true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["@dcloudio/types"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "components/**/*.ts",
    "components/**/*.d.ts",
    "../shared/**/*.d.ts" // 这个是为了在shared不编译时也能得到global-extend的提示
  ],
}
